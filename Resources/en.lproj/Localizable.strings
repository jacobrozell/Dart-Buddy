"play.rules.fleet.overview.title" = "Overview";
"play.rules.fleet.overview.body" = "Hide your fleet on the board. Take turns calling a cell, throwing, and sinking enemy ships before yours are gone.";
"play.rules.fleet.placement.title" = "Place your fleet";
"play.rules.fleet.placement.body" = "Pick exactly three, five, or seven different cells. On one phone, each player takes a private turn to place and lock ships.";
"play.rules.fleet.shipHealth.title" = "Ship health";
"play.rules.fleet.shipHealth.body" = "Fragile ships sink on one damaging hit. Armored ships need three hits unless a triple sinks them immediately.";
"play.rules.fleet.hunt.title" = "Calling and throwing";
"play.rules.fleet.hunt.body" = "On your turn you have three darts. Call a segment, then throw. In strict mode your dart must land on the called segment.";
"play.rules.fleet.hits.title" = "Hits and misses";
"play.rules.fleet.hits.body" = "Single = 1 hit, double = 2 hits, triple = instant sink. No ship there means clear.";
"play.rules.fleet.sonar.title" = "Sonar";
"play.rules.fleet.sonar.body" = "Once per match, pick a segment and learn whether your opponent still has a ship there.";
"play.rules.fleet.winning.title" = "Winning";
"play.rules.fleet.winning.body" = "Sink all of your opponent's ships first to win.";
"play.rules.raid.overview.title" = "Overview";
"play.rules.raid.overview.body" = "Work together to defeat the boss before you run out of hearts. Take turns throwing three darts each. The boss fight has two damage phases — cricket closes, then doubles — and enrage punishes weak rounds when the boss is almost down.";
"play.rules.raid.shield.title" = "Shield phase";
"play.rules.raid.shield.body" = "While the boss has high health, only twenty through sixteen matter. Your team shares cricket marks on those numbers. Closing a number deals eight damage. Other segments do nothing in this phase.";
"play.rules.raid.expose.title" = "Expose phase";
"play.rules.raid.expose.body" = "When the boss is wounded, doubles deal two damage anywhere and triples deal three. Singles score no damage — go big or go home.";
"play.rules.raid.enrage.title" = "Enrage";
"play.rules.raid.enrage.body" = "When the boss is nearly defeated, enrage activates. After each full round of hero throws, the boss strikes. With two or more players, whoever had the lowest visit total loses a heart. Solo? Score at least sixty on your visit or lose a heart.";
"play.rules.raid.hearts.title" = "Hearts and down";
"play.rules.raid.hearts.body" = "Each hero starts with a limited number of hearts. Lose them all and you're down — you skip turns. If every hero is down, the boss wins.";
"play.rules.raid.winning.title" = "Winning";
"play.rules.raid.winning.body" = "Reduce the boss to zero health before the team is wiped out.";
