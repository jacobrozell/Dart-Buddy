"play.rules.sheet.title" = "How to play";
"play.rules.sheet.done" = "Done";
"play.rules.x01.overview.title" = "The game";
"play.rules.x01.overview.body" = "Each player starts at the starting score you pick (101, 201, 301, 401, 501, or 601) and throws three darts per turn. Subtract your turn total from your remaining score. The first player to reach exactly zero wins the leg under your leg and set settings.";
"play.rules.x01.bust.title" = "Busts";
"play.rules.x01.bust.body" = "If a turn would take you below zero, leave 1 on double-out or master-out, or break the check-in or check-out rule, the turn busts: your score returns to what it was at the start of the turn and play passes to the next player.";
"play.rules.x01.checkIn.title" = "Check-in";
"play.rules.x01.checkIn.body" = "Straight In: every dart in your visit counts from your first scoring throw.\n\nDouble In: you must hit a double (or inner bull when your league counts it) before any other darts in the visit count.\n\nMaster In: you must hit a double or triple (or inner bull when your league counts it) before earlier singles in the visit count.";
"play.rules.x01.checkOut.title" = "Check-out";
"play.rules.x01.checkOut.body" = "Straight Out: you may finish on any dart that reaches exactly zero.\n\nDouble Out: you must reach exactly zero on a double (or inner bull when your league counts it as a double).\n\nMaster Out: you must reach exactly zero on a double or triple (or inner bull when your league counts it as a double).";
"play.rules.x01.format.title" = "Legs and sets";
"play.rules.x01.format.body" = "Use the setup chips for starting score, check-in, check-out, legs to win, optional sets, and first-to or best-of leg format.";
"play.rules.cricket.basics.title" = "Cricket basics";
"play.rules.cricket.basics.body" = "Close targets 20 through 15 and the bull by landing marks. Singles, doubles, and triples add 1, 2, or 3 marks. A target closes at three marks. Outer bull counts as one mark; inner bull counts as two.";
"play.rules.cricket.normalScore.title" = "Normal · Points on";
"play.rules.cricket.normalScore.body" = "While at least one opponent has not closed a target, extra marks on a closed target become points on that number.\n\nWhen everyone has closed all targets, the leg ends. Highest total score wins the leg.";
"play.rules.cricket.cutThroatScore.title" = "Cut Throat · Points on";
"play.rules.cricket.cutThroatScore.body" = "Overflow points are credited to opponents who have not closed that target—the more marks you add, the more points they receive.\n\nWhen the board is fully closed, the leg ends. Lowest total score wins the leg.";
"play.rules.cricket.noScore.title" = "No score (points off)";
"play.rules.cricket.noScore.body" = "Marks still close targets, but no points are scored. The leg ends when you close all targets on your turn—you win that leg immediately.";
